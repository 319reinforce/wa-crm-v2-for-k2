{
  "name": "wa-crm-v2",
  "version": "1.0.0",
  "description": "WhatsApp CRM v2 - MySQL based",
  "main": "server/index.cjs",
  "scripts": {
    "start": "node server/index.cjs",
    "wa:crawler": "node server/waCrawler.cjs",
    "pm2:wa:start": "bash scripts/wa-pm2.sh start",
    "pm2:wa:stop": "bash scripts/wa-pm2.sh stop",
    "pm2:wa:restart": "bash scripts/wa-pm2.sh restart",
    "pm2:wa:status": "bash scripts/wa-pm2.sh status",
    "pm2:wa:logs": "bash scripts/wa-pm2.sh logs",
    "pm2:wa:doctor": "bash scripts/wa-pm2.sh doctor",
    "pm2:wa:logrotate": "bash scripts/wa-pm2.sh setup-logrotate",
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0 --port 3001",
    "prebuild": "rm -rf public/assets public/index.html",
    "build": "vite build",
    "test": "node scripts/test-smoke.cjs",
    "test:full": "node -e \"process.env.SMOKE_INCLUDE_API_IT='1'; require('./scripts/test-smoke.cjs').main()\"",
    "test:ci": "node -e \"process.env.SMOKE_INCLUDE_API_IT='1'; process.env.SMOKE_INCLUDE_UI_IT='1'; require('./scripts/test-smoke.cjs').main()\"",
    "test:unit": "node --test tests/**/*.test.mjs",
    "test:api:strategy": "node scripts/test-strategy-config-api.cjs",
    "test:api:lifecycle": "node scripts/test-lifecycle-api.cjs",
    "test:api:events": "node scripts/test-events-api.cjs",
    "events:truth:minimax": "node scripts/minimax-event-truth-set.cjs",
    "events:backfill:minimax": "node scripts/backfill-minimax-events.cjs",
    "events:recompute:minimax": "node scripts/backfill-minimax-events.cjs --all --write --rebuild-lifecycle",
    "test:data:group-pollution:purge": "node scripts/purge-group-pollution.cjs",
    "test:data:group-pollution": "node scripts/check-group-pollution-regression.cjs",
    "test:ui:acceptance": "node scripts/test-ui-acceptance.cjs",
    "wa:smoke": "node scripts/wa-send-smoke.cjs",
    "wa:qr": "node scripts/watch-wa-qr.cjs",
    "wa:qr:single": "node scripts/watch-wa-qr.cjs single --session yiyun",
    "wa:qr:batch": "node scripts/watch-wa-qr.cjs batch --start beau",
    "wa:qr:watch": "npm run wa:qr:single",
    "wa:beau:heartbeat": "node scripts/beau-nightly-role-heartbeat.cjs",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0 --port 3001",
    "lifecycle:migrate": "node migrate-lifecycle-state.js",
    "wa:sessions:migrate": "node migrate-wa-sessions.js",
    "wa:driver:migrate": "node migrate-wa-sessions-driver.js",
    "db:seed:ai-providers": "node scripts/seed-ai-provider-configs.cjs",
    "wa:sessions:bootstrap": "node server/bootstrap/migrateLegacySessions.js",
    "lifecycle:backfill": "node migrate-lifecycle-state.js --backfill",
    "cleanup:creators": "node scripts/cleanup-invalid-creators.cjs",
    "cleanup:merge-creator-duplicate": "node scripts/merge-creator-duplicate.cjs",
    "train:local": "node scripts/train-sft-local.cjs",
    "sft:prepare:safe": "node scripts/prepare-safe-finetune-jsonl.cjs",
    "sft:repair:system-prompt": "node scripts/backfill-sft-system-prompt-used.cjs",
    "rag:env:check": "node scripts/check-openai-rag-env.cjs",
    "rag:manifest:check": "node scripts/validate-knowledge-manifest.cjs",
    "rag:sync": "node scripts/sync-openai-vector-store.cjs",
    "rag:query": "node scripts/query-openai-vector-store.cjs",
    "rag:obs:start": "node scripts/start-rag-observation.cjs",
    "rag:obs:finish": "node scripts/finish-rag-observation.cjs",
    "metrics:launch:start": "node scripts/start-formal-launch-metrics.cjs",
    "metrics:launch:report": "node scripts/finish-rag-observation.cjs --from-launch",
    "sft:align:rules": "node scripts/align-sft-rule-version.cjs",
    "report:canary:send": "node scripts/send-canary-daily-report.cjs",
    "report:canary:send:exec": "node scripts/send-canary-daily-report.cjs --executive",
    "ab:readiness": "node scripts/ab-takeover-readiness.cjs",
    "ab:smoke": "node scripts/finetuned-canary-smoke.cjs",
    "ab:rollout": "node scripts/run-finetuned-canary-rollout.cjs",
    "mock:finetuned": "node scripts/mock-finetuned-server.cjs"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.8",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "deepl-node": "^1.26.0",
    "dotenv": "^16.6.1",
    "emoji-picker-react": "^4.18.0",
    "express": "^4.21.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.6.1",
    "mime-types": "^2.1.35",
    "mysql2": "^3.20.0",
    "openai": "^6.34.0",
    "pino": "^9.7.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.9.0",
    "react-router-dom": "^6.22.3",
    "sharp": "^0.33.5",
    "whatsapp-web.js": "^1.26.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.27.7",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3"
  }
}
