# Public-safe environment template (no real secrets)
# Copy to .env and replace placeholders with real values.

# MySQL
DB_PASSWORD=your_mysql_password
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_NAME=wa_crm_v2

# OpenAI (only required when USE_OPENAI=true)
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
USE_OPENAI=false

# MiniMax (used when USE_OPENAI=false)
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_API_BASE=https://api.minimaxi.com/anthropic

# Optional switches
DISABLE_WA_SERVICE=false
DISABLE_WA_WORKER=false
