# MySQL 数据库
DB_PASSWORD=030319
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_NAME=wa_crm_v2

# OpenAI
OPENAI_API_KEY=***REMOVED***
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
USE_OPENAI=true
OPENAI_RAG_ENABLED=false
OPENAI_VECTOR_STORE_ID=
OPENAI_RAG_TOP_K=8
KNOWLEDGE_MANIFEST_PATH=docs/rag/knowledge-manifest.json
AI_PROXY_TOKEN=replace_with_strong_token

# MiniMax
MINIMAX_API_KEY=***REMOVED***
MINIMAX_API_BASE=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# MiniMax translation endpoint (dedicated key/base; falls back to MINIMAX_API_* if unset)
MINIMAX_TRANSLATION_API_KEY=***REMOVED***
MINIMAX_TRANSLATION_API_BASE=https://minimax.a7m.com.cn

# Translation provider routing
#   - TRANSLATION_PROVIDER: 'deepl' | 'minimax' (default: minimax — 保持向后兼容)
#   - 前端可在 /api/translate body 里传 provider 覆盖 env
#   - DeepL 失败会自动 fallback 到 MiniMax
TRANSLATION_PROVIDER=minimax
DEEPL_API_KEY=
# 可选：自定义 DeepL endpoint（免费账户 SDK 会自动识别，一般不用设）
DEEPL_API_BASE=
# Glossary id（首次启动调 createGlossary 后日志会打印 id，填回这里避免每次重建）
DEEPL_GLOSSARY_EN_ZH=
DEEPL_GLOSSARY_ZH_EN=
# DeepL 每日字符配额闸门（0 或未设 = 关闭）。仅约束 provider=deepl 成功请求，
# MiniMax 不受限。超额返回 429 TRANSLATION_QUOTA_EXCEEDED，不 fallback。
# Free plan 50 万字符/月，日均 ~16000；建议设 20000 留缓冲。
TRANSLATION_MAX_CHARS_PER_DAY=0

# Optional runtime switches (local debug / CI)
JSON_BODY_LIMIT=15mb
WA_SESSION_ID=
WA_OWNER=Beau
WA_AUTH_ROOT=
WA_HEADLESS=true
PUPPETEER_EXECUTABLE_PATH=
WA_PUPPETEER_ARGS=
# 独立 crawler 进程回调主服务地址（用于 profile-agent 事件）
WA_API_BASE=http://127.0.0.1:3000

# Training / canary
TRAINING_TRIGGER_TOKEN=training-trigger-token
TRAINING_SCRIPT=
TRAINING_DRY_RUN=true
TRAINING_API_TIMEOUT_MS=30000
USE_FINETUNED=false
FINETUNED_BASE=http://localhost:8000/v1/messages
FINETUNED_MODEL=
AB_RATIO=0.1
CANARY_API_BASE=http://localhost:3001

# Media upload / send
MEDIA_UPLOAD_MAX_BYTES=8388608
MEDIA_STORAGE_PROVIDER=local
MEDIA_LOCAL_DIR=./data/media-assets
# 如果本地目录挂载到对象存储/CDN，可填公开前缀
MEDIA_PUBLIC_BASE_URL=

# Incoming WA media download（支持图片/视频/音频/PDF）
# 覆盖 incoming media 文件大小限制（默认 50MB）
# WA_INCOMING_MEDIA_MAX_BYTES=52428800

# Rule alignment / metrics window
SFT_RULE_VERSION=2026-04-15
SFT_RULE_EFFECTIVE_DATE=2026-04-15
SFT_BACKFILL_SINCE=
SFT_BACKFILL_UNTIL=
FORMAL_LAUNCH_MARKER_PATH=docs/rag/formal-launch-window.json
# LAN access control
API_AUTH_TOKEN=replace-with-a-long-random-token
APP_LOGIN_USERNAME=k2
APP_LOGIN_PASSWORD=replace-with-a-password
# 本地开发时才显式开启；生产环境必须保持 false 或留空
LOCAL_API_AUTH_BYPASS=false
